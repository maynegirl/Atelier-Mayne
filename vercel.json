{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ateliermayne.com" }],
      "destination": "https://www.ateliermayne.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/website_images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/brand_assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
